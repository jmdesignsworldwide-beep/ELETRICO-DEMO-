# ── Supabase ─────────────────────────────────────────────
# Solo la URL y la anon key son públicas.
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# service_role: SOLO servidor, jamás con prefijo NEXT_PUBLIC_.
# Marcar como Sensitive en Vercel. Nunca commitear el valor real.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui
